# Optional for local dev (Vite proxies to localhost:3001 by default).
# Required for Netlify: set VITE_SERVER_URL in Netlify dashboard, not in a file.

# VITE_SERVER_URL=https://your-server.onrender.com

# TURN / ICE settings for proximity voice.
#
# Chrome works with STUN alone on most networks. Firefox CANNOT resolve
# Chrome's mDNS `.local` ICE candidates, so Firefox↔Chrome connections on the
# same LAN will fail with "ICE failed" without a TURN relay. TURN is also
# required on symmetric-NAT networks (mobile carriers, corporate VPNs).
#
# Free / low-cost TURN options: Metered (metered.ca), Twilio (has free tier),
# open.relay.metered.ca (public demo — NOT for production).
#
# VITE_ICE_SERVERS_JSON overrides everything if set (include STUN + TURN):
# VITE_ICE_SERVERS_JSON=[{"urls":"stun:stun.l.google.com:19302"},{"urls":"turn:turn.example.com:3478","username":"demo","credential":"demo"}]

# Or set these three individually:
# VITE_TURN_URL=turn:turn.example.com:3478
# VITE_TURN_USERNAME=demo
# VITE_TURN_CREDENTIAL=demo
