# Optional for local dev (Vite proxies to localhost:3001 by default).
# Required for Netlify: set VITE_SERVER_URL in Netlify dashboard, not in a file.

# VITE_SERVER_URL=https://your-server.onrender.com

# Voice uses LiveKit. Configure LIVEKIT_* on the SERVER (see docs/LIVEKIT.md).
#
# Firefox↔Chromium: Firefox may need TURN to reach LiveKit. If audio fails between
# Firefox and Chrome, set these (or VITE_ICE_SERVERS_JSON):
# VITE_TURN_URL=turn:your-turn.example.com:3478
# VITE_TURN_USERNAME=user
# VITE_TURN_CREDENTIAL=secret
