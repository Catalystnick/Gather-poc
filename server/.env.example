# Server port (default 3001)
# PORT=3001

# Supabase — required for auth. Your project URL from Supabase dashboard → Settings → API.
SUPABASE_URL=https://your-project-ref.supabase.co
# Service role key required for server-side tenant APIs (never expose to client).
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# Optional: in-memory cache TTL for tenant context resolution (milliseconds).
# TENANT_CONTEXT_TTL_MS=60000
# Feature flags for staged tenant rollout.
# ENABLE_TENANT_ROUTES=true
# ENABLE_INTERNAL_OBSERVABILITY_ROUTES=true
# Optional socket auth checkpointing for long sessions.
# Set SOCKET_AUTH_CHECKPOINT_MS > 0 to enable periodic token checkpoints.
# SOCKET_AUTH_CHECKPOINT_MS=300000
# SOCKET_AUTH_CHECKPOINT_TIMEOUT_MS=10000
# Optional observability output:
# OBSERVABILITY_LOG_INTERVAL_MS=60000
# Optional key to protect /internal/observability endpoint.
# OBSERVABILITY_INTERNAL_KEY=change-me
# Optional vars for running `npm run test:rls`.
# SUPABASE_ANON_KEY=your-anon-key
# TENANT_RLS_TEST_USER_TOKEN=jwt-for-authenticated-test-user

# Optional invite email delivery (SMTP; Gmail-compatible).
# If unset, invite creation still works and returns token/link fallback.
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=465
# SMTP_SECURE=true
# SMTP_USER=your-sender@gmail.com
# SMTP_PASS=your-16-char-app-password
# Optional from address display. Defaults to SMTP_USER.
# INVITE_FROM_EMAIL=Gather <your-sender@gmail.com>
# Optional absolute URL used to build invite links sent in email.
# Defaults to http://localhost:5173/invite/accept in non-production.
# TENANT_INVITE_ACCEPT_URL=https://app.your-domain.com/invite/accept

# LiveKit — required for proximity voice. See docs/LIVEKIT.md.
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=your-api-key
LIVEKIT_API_SECRET=your-api-secret
