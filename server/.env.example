# Server port (default 3001)
# PORT=3001

# Supabase — required for auth. Your project URL from Supabase dashboard → Settings → API.
SUPABASE_URL=https://your-project-ref.supabase.co
# Service role key required for server-side tenant APIs (never expose to client).
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# Optional: in-memory cache TTL for tenant context resolution (milliseconds).
# TENANT_CONTEXT_TTL_MS=60000
# Feature flags for staged tenant rollout.
# ENABLE_TENANT_ROUTES=true
# ENABLE_TENANT_SOCKET_CONTEXT=true
# Optional vars for running `npm run test:rls`.
# SUPABASE_ANON_KEY=your-anon-key
# TENANT_RLS_TEST_USER_TOKEN=jwt-for-authenticated-test-user

# LiveKit — required for proximity voice. See docs/LIVEKIT.md.
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=your-api-key
LIVEKIT_API_SECRET=your-api-secret
